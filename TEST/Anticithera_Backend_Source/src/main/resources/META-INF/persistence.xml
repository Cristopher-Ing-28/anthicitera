<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.0" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd">
    <persistence-unit name="AnticitheraPU" transaction-type="JTA">
        <jta-data-source>jdbc/AnticitheraDS</jta-data-source>
        <class>com.anticithera.backend.entity.Usuario</class>
        <class>com.anticithera.backend.entity.SesionActividad</class>
        <class>com.anticithera.backend.entity.ExportacionZip</class>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="update"/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.MariaDBDialect"/>
        </properties>
    </persistence-unit>
</persistence>
